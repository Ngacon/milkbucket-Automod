DISCORD_TOKEN=your_discord_bot_token
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/milkbucket
REDIS_URL=redis://127.0.0.1:6379
LOG_LEVEL=info
AUTO_SYNC_SCHEMA=true
ENABLE_REDIS_CACHE=true
LOG_COMMANDS=true
REDIS_KEY_PREFIX=milkbucket:
PG_POOL_MAX=20
PG_IDLE_TIMEOUT_MS=30000
PG_CONNECT_TIMEOUT_MS=10000
